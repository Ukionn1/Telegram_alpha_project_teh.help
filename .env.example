BOT_TOKEN=123456:replace_me
MODERATORS=111111111,222222222

# polling - local/dev, webhook - Beget VPS/production with HTTPS reverse proxy
RUN_MODE=polling

DB_PATH=data/support.db
UPLOADS_DIR=data/uploads
SUPPORT_TITLE=Поддержка

# Required for Telegram Mini App and webhook mode.
PUBLIC_BASE_URL=https://support.example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=replace_with_long_random_secret
HOST=0.0.0.0
PORT=8080

# Local-only helper for opening the mini app outside Telegram during development.
# Use an existing moderator Telegram user id.
WEBAPP_DEV_USER_ID=
